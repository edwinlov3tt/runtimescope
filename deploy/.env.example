# Production deployment environment variables
# Copy to .env and fill in values. Never commit .env.

# REQUIRED: Random secret used to authenticate SDK connections.
# Generate with: openssl rand -hex 32
AUTH_TOKEN=

# Your public domain (for reference — also update deploy/Caddyfile)
# DOMAIN=runtimescope.yourcompany.com

# Optional overrides (defaults shown)
# RUNTIMESCOPE_BUFFER_SIZE=10000
# RUNTIMESCOPE_RETENTION_DAYS=30
