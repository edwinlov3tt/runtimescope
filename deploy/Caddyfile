# Caddy config for RuntimeScope Collector
# Replace `runtimescope.example.com` with your actual domain.
# Caddy automatically provisions Let's Encrypt certificates for HTTPS/WSS.

runtimescope.example.com {
    # WebSocket upgrade for SDK connections → collector:9090
    @websocket {
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    reverse_proxy @websocket collector:9090

    # HTTP API (REST + event ingestion + SDK bundle) → collector:9091
    reverse_proxy collector:9091

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        # CORS — allow from anywhere since SDKs come from user apps
        Access-Control-Allow-Origin  "*"
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
    }

    encode gzip zstd
    log {
        output file /data/access.log
        format json
    }
}
