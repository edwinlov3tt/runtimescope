{
  "name": "runtimescope",
  "private": true,
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard": "node packages/collector/dist/dashboard.js",
    "playground": "npm run dev -w playground",
    "stress": "tsx stress/cli.ts",
    "stress:quick": "tsx stress/cli.ts -- --quick",
    "prepush": "npm run build && npm test && npm run stress -- --quick"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
