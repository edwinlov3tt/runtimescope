{
  "name": "@runtimescope/sdk",
  "version": "0.6.0",
  "description": "Zero-dependency browser SDK for RuntimeScope runtime profiling and telemetry",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "default": "./dist/index.global.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": ["runtime", "profiler", "telemetry", "observability", "sdk", "browser"],
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
